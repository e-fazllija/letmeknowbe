# ===========================================
# LetMeKnow API - .env.production.example
# ===========================================
# TEMPLATE per:
# - AZURE TEST (es. lmk-api-test.azurewebsites.net)
# - PROD con dominio finale (api.let-me-know.it / app.let-me-know.it)
#
# NON mettere segreti reali in questo file nel repo.
# Copia i valori in Azure App Service (Configuration).

# ===========================================
# 1) URL / CORS / COOKIE - AZURE TEST (ESEMPIO)
# ===========================================
# Slot / App Service di test, ancora senza dominio custom.

# FRONTEND_BASE_URL=https://lmk-frontend-test.azurewebsites.net
# API_BASE_URL=https://lmk-api-test.azurewebsites.net/v1
# CORS_ALLOWED_ORIGINS=https://lmk-frontend-test.azurewebsites.net
# COOKIE_DOMAIN=                     # Vuoto: cookie legati all'host; più semplice per i primi test
# COOKIE_SECURE=true                 # In Azure: sempre HTTPS => true
# COOKIE_SAMESITE=none               # FE e API su host diversi => none

# CSRF_PROTECTION=false              # TEST: false per evitare 403 finché il FE non manda X-CSRF-Token
#                                    # PROD: portare a true dopo aver testato il flusso CSRF con FE

# Antivirus allegati (AZURE TEST, senza ClamAV)
# ATTACH_SCAN_ENABLED=false          # Nessuno scan finché ClamAV non è disponibile
# ALLOW_UNSCANNED_DOWNLOAD=true      # Permetti download anche se non scansionati (come dev)
# DELETE_INFECTED=false
# CLAMAV_HOST=
# CLAMAV_PORT=3310

# Retention (AZURE TEST)
# RETENTION_ENABLED=true
# RETENTION_TIMER_MS=60000           # 60s: vedi subito i log
# RETENTION_DRY_RUN=true             # NON cancella davvero, solo logga/aggiorna retentionAt
# RETENTION_BATCH=50
# DATA_RETENTION_YEARS=1             # Basso per simulare dati vecchi

# Trascrizione (AZURE TEST)
# TRANSCRIBE_ENABLED=false           # Inizialmente off
# TRANSCRIBE_TIMER_MS=60000          # Intervallo scheduler (default 5 min); in test puoi tenerlo più basso
# TRANSCRIBE_ENGINE=MOCK
# WHISPER_URL=
# WHISPER_MODEL=


# ===========================================
# 2) URL / CORS / COOKIE - DOMINIO FINALE (PROD)
# ===========================================
# Dopo aver configurato DNS + HTTPS per i domini finali.

# FRONTEND_BASE_URL=https://app.let-me-know.it
# API_BASE_URL=https://api.let-me-know.it/v1
# CORS_ALLOWED_ORIGINS=https://app.let-me-know.it
# COOKIE_DOMAIN=let-me-know.it        # Cookie validi per dominio principale (e sottodomini)
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none               # Cross-site: none + secure=true

# CSRF_PROTECTION=true               # Abilita protezione CSRF (double-submit cookie+header)

# Antivirus allegati (PROD, con ClamAV attivo)
# ATTACH_SCAN_ENABLED=true
# ATTACH_SCAN_TIMER_MS=60000
# CLAMAV_HOST=clamav.internal        # Host del servizio ClamAV
# CLAMAV_PORT=3310
# DELETE_INFECTED=true
# ALLOW_UNSCANNED_DOWNLOAD=false     # In prod scarica solo allegati CLEAN

# Retention (PROD)
# RETENTION_ENABLED=true
# RETENTION_TIMER_MS=86400000        # 24h
# RETENTION_DRY_RUN=false            # Cancella davvero
# RETENTION_BATCH=200
# DATA_RETENTION_YEARS=5             # Allineato a policy/normativa

# Trascrizione (PROD, con Whisper)
# TRANSCRIBE_ENABLED=true
# TRANSCRIBE_TIMER_MS=300000         # 5 min scheduler trascrizione
# TRANSCRIBE_ENGINE=WHISPER_LOCAL    # Scheduler usa Whisper locale
# WHISPER_URL=https://whisper.internal/transcribe
# WHISPER_MODEL=small                # Nome modello supportato dal servizio Python


# ===========================================
# 3) COMMON - VALE PER TEST E PROD (PLACEHOLDER)
# ===========================================

# ---------- Assignment / Visibility ----------
AUTO_ASSIGN_MODE=NONE
CAN_ADMINS_BYPASS_ASSIGNMENT=true
REQUIRE_ASSIGNMENT_FOR_OPS_AGENT=true
REQUIRE_ASSIGNMENT_FOR_OPS_ADMIN=false
CLAIM_REQUIRE_ACTIVE=true

# ---------- Notifications / Email ----------
NOTIFY_ON_NEW_PUBLIC_REPORT=true
NOTIFY_ON_NEW_PUBLIC_VOICE=true
NOTIFY_ON_ASSIGN=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false                           # 587 => false (STARTTLS); 465 => true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=LetMeKnow <no-reply@example.com>

INVITE_EMAIL_ENABLED=true

# ---------- Presign / Attachments ----------
PRESIGN_ENABLED=true
PRESIGN_MODE=REAL
PRESIGN_PROOF_REQUIRED=true
PRESIGN_PROOF_SECRET=please_change_presign_proof_secret
UPLOAD_FINALIZE_SECRET=please_change_finalize_secret
ATTACH_MAX_FILES=3
ATTACH_MAX_FILE_MB=10
ATTACH_MAX_TOTAL_MB=20

# --- Scenario: allegati DISABILITATI (qualsiasi storage) ---
# Usa questo blocco quando vuoi rilasciare senza upload allegati
# e lavorare sull'integrazione storage senza rischio.
#PRESIGN_ENABLED=false
#PRESIGN_MODE=REAL
#ATTACH_MAX_FILES=3
#ATTACH_MAX_FILE_MB=10
#ATTACH_MAX_TOTAL_MB=20

# --- Scenario: allegati ABILITATI (qualsiasi storage) ---
# Usa questo blocco quando sei certo che lo storage (S3 o Azure)
# sia configurato e testato.
#PRESIGN_ENABLED=true
#PRESIGN_MODE=REAL
#PRESIGN_PROOF_REQUIRED=true
#PRESIGN_PROOF_SECRET=please_change_presign_proof_secret
#UPLOAD_FINALIZE_SECRET=please_change_finalize_secret
#ATTACH_MAX_FILES=3
#ATTACH_MAX_FILE_MB=10
#ATTACH_MAX_TOTAL_MB=20


# ---------- Database ----------
PUBLIC_DATABASE_URL=postgresql://user:pass@db-host:5432/LetMeKnow-client?schema=public
TENANT_DATABASE_URL=postgresql://user:pass@db-host:5432/LetMeKnow-tenant?schema=public

# ---------- JWT & Sessions ----------
JWT_ACCESS_SECRET=please_rotate_access_secret
JWT_REFRESH_SECRET=please_rotate_refresh_secret
ACCESS_TTL=900s
REFRESH_TTL=30d
TENANT_JWT_ISS=letmeknow
TENANT_JWT_AUD=letmeknow-app

# ---------- MFA ----------
JWT_MFA_SECRET=please_rotate_mfa_jwt_secret
MFA_TOKEN_TTL=300s
MFA_ENC_KEY=please_provide_32B_key_hex_or_base64
MFA_ISSUER=LetMeKnow
RECOVERY_CODE_PEPPER=please_rotate_recovery_code_pepper

# ---------- Runtime ----------
NODE_ENV=production
HTTP_LOG_ENABLED=true

# ---------- Tenant Context / Allowlist ----------
TENANT_ID_ALLOWLIST=                        # Vuoto = tutti i tenant attivi

# ---------- Security Peppers ----------
REPORT_SECRET_COST=12
REPORT_SECRET_PEPPER=please_rotate_report_secret_pepper
IP_HASH_PEPPER=please_rotate_ip_hash_pepper
PII_CHECK_ENABLED=true

# ---------- Storage (S3 / Azure Blob compat) ----------
# Provider di storage oggetti:
# - S3           => S3/MinIO (compatibile con versione attuale)
# - AZURE_BLOB   => Azure Blob Storage (usando i container come bucket)
STORAGE_PROVIDER=S3

# Config S3/MinIO (se STORAGE_PROVIDER=S3)
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_TMP=letmeknow-temp
S3_BUCKET_ATTACH=letmeknow-attach
S3_SSE_MODE=S3
S3_KMS_KEY_ID=

# Config Azure Blob (se STORAGE_PROVIDER=AZURE_BLOB)
# I nomi S3_BUCKET_TMP/S3_BUCKET_ATTACH vengono usati come nomi dei container.
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_account_key
# Opzionale: override endpoint (es. Azurite); vuoto => https://<account>.blob.core.windows.net
AZURE_STORAGE_ENDPOINT=

# --- Scenario: S3/MinIO ---
#STORAGE_PROVIDER=S3
#S3_ENDPOINT=                           # es: https://s3.eu-central-1.amazonaws.com o http://minio:9000
#S3_REGION=eu-central-1
#S3_ACCESS_KEY=your_access_key
#S3_SECRET_KEY=your_secret_key
#S3_BUCKET_TMP=letmeknow-temp
#S3_BUCKET_ATTACH=letmeknow-attach
#S3_SSE_MODE=S3
#S3_KMS_KEY_ID=

# --- Scenario: Azure Blob ---
#STORAGE_PROVIDER=AZURE_BLOB
#S3_BUCKET_TMP=letmeknow-temp          # usati come nomi dei container
#S3_BUCKET_ATTACH=letmeknow-attach
#AZURE_STORAGE_ACCOUNT=your_storage_account_name
#AZURE_STORAGE_KEY=your_storage_account_key
#AZURE_STORAGE_ENDPOINT=               # opzionale; vuoto => https://<account>.blob.core.windows.net

# ---------- SLA / Reminder ----------
SLA_REMINDER_ENABLED=true
SLA_TIMER_MS=86400000                       # 24h in prod (in test puoi ridurlo)
ACK_TTL_DAYS=7
RESPONSE_TTL_DAYS=90
ACK_REMIND_DAYS=2,3,7
RESPONSE_REMIND_DAYS=30,60,80,90

# ---------- Data Retention ----------
RETENTION_ENABLED=true
RETENTION_MODE=HARD
DATA_RETENTION_YEARS=5
# DATA_RETENTION_DAYS=
RETENTION_TIMER_MS=86400000
RETENTION_BATCH=200
RETENTION_DRY_RUN=false

# ---------- Transcription (default OFF, vedi blocchi sopra) ----------
TRANSCRIBE_ENABLED=false
TRANSCRIBE_TIMER_MS=300000
TRANSCRIBE_ENGINE=MOCK
# WHISPER_URL=
# WHISPER_MODEL=

# ---------- Public Receipt ----------
PUBLIC_AUTO_ACK=true
PUBLIC_ACK_TTL_DAYS=7

# ---------- Reporter PII Encryption ----------
REPORTER_DATA_ENC_KEY=please_provide_base64_32B_key

# ---------- Platform superuser ----------
PLATFORM_SUPER_EMAIL=admin@letmeknow.local
PLATFORM_SUPER_HASH=please_set_bcrypt_hash
PLATFORM_MFA_SECRET=please_set_platform_mfa_secret
JWT_PLATFORM_ACCESS_SECRET=please_rotate_platform_access_secret
PLATFORM_ACCESS_TTL=14400s
PLATFORM_JWT_ISS=letmeknow-platform
PLATFORM_JWT_AUD=platform
PLATFORM_IP_ALLOWLIST=
PLATFORM_PROTECT_PUBLIC_ADMIN=false

# ---------- Stripe (prod) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
#STRIPE_API_VERSION=2024-06-20
