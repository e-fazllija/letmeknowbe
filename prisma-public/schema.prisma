// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/public"
}

datasource db {
  provider = "postgresql"
  url      = env("PUBLIC_DATABASE_URL") // es: postgresql://postgres:password@localhost:5432/whistledb_INTENT
}

enum PaymentMethod {
  CARTA
  BONIFICO
}

enum EmployeeRange {
  DA_0_A_50
  DA_51_A_100
  DA_101_A_150
  DA_151_A_200
  DA_201_A_250
  OLTRE_250
}

// NEW: stato cliente
enum ClientStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

// NEW: ciclo di fatturazione
enum BillingCycle {
  MENSILE
  ANNUALE
}

// NEW: durata contrattuale
enum ContractTerm {
  ONE_YEAR
  THREE_YEARS
}

// NEW: stato abbonamento
enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

// CLIENT (azienda)
model Client {
  id            String         @id @default(cuid())
  companyName   String
  contactEmail  String
  status        ClientStatus   @default(ACTIVE)
  employeeRange EmployeeRange
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Billing fields (fonte di verità in PUBLIC)
  billingTaxId        String  @unique
  billingEmail        String
  billingPec          String?
  billingSdiCode      String?
  billingAddressLine1 String
  billingZip          String
  billingCity         String
  billingProvince     String
  billingCountry      String

  @@index([companyName])
}

// ABBONAMENTI
model Subscription {
  id            String             @id @default(cuid())
  clientId      String
  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount        Decimal            @db.Decimal(10, 2)
  currency      String             @default("EUR")
  billingCycle  BillingCycle
  contractTerm  ContractTerm
  method        PaymentMethod
  status        SubscriptionStatus @default(ACTIVE)
  startsAt      DateTime           @default(now())
  nextBillingAt DateTime?
  trialEndsAt   DateTime?
  canceledAt    DateTime?
  createdAt     DateTime           @default(now())
}
