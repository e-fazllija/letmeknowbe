// ---------- GENERATOR & DATASOURCE ----------
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

////////////////////////////////////////////////////
// ENUM
////////////////////////////////////////////////////
enum PaymentMethod {
  CARTA
  BONIFICO
}

enum EmployeeRange {
  DA_0_A_50
  DA_51_A_100
  DA_101_A_150
  DA_151_A_200
  DA_201_A_250
  OLTRE_250
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  SUSPENDED
  NEED_INFO
  CLOSED
}

enum ReportChannel {
  WEB
  PHONE
  EMAIL
  OTHER
}

// Privacy del segnalante
enum ReporterPrivacy {
  ANONIMO
  CONFIDENZIALE
}

// Stato cliente (coerente col public)
enum ClientStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

// Ciclo fatturazione (coerente col public)
enum BillingCycle {
  MENSILE
  ANNUALE
}

// Durata contrattuale (coerente col public)
enum ContractTerm {
  ONE_YEAR
  THREE_YEARS
}

// Stato subscription (coerente col public)
enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

// --- NEW: User/Invite/Session enums ---
enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum UserRole {
  ADMIN
  AGENT
  AUDITOR
}

enum UserTokenType {
  INVITE
  RESET
  VERIFY
}

////////////////////////////////////////////////////
// MODELS
////////////////////////////////////////////////////

// Lookup per-tenant: Reparti
model Department {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]

  @@index([clientId, active, sortOrder])
}

// Lookup per-tenant: Categorie (per reparto)
model Category {
  id           String     @id @default(cuid())
  clientId     String
  departmentId String
  name         String
  active       Boolean    @default(true)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  department Department @relation(fields: [departmentId], references: [id])

  @@index([clientId, departmentId, active, sortOrder])
}

// Azienda cliente (tenant)
model Client {
  id            String         @id @default(cuid())
  companyName   String
  contactEmail  String
  status        ClientStatus   @default(ACTIVE)
  employeeRange EmployeeRange
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyName])
}

// Abbonamenti (shadow minimale nel tenant: NO dati economici)
model Subscription {
  id            String             @id @default(cuid())
  clientId      String
  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  billingCycle  BillingCycle
  contractTerm  ContractTerm
  status        SubscriptionStatus @default(ACTIVE)
  startsAt      DateTime           @default(now())
  nextBillingAt DateTime?
  createdAt     DateTime           @default(now())

  @@index([clientId])
}

// Utenti interni (admin, agent)
model InternalUser {
  id              String     @id @default(cuid())
  clientId        String
  email           String
  password        String
  role            UserRole
  status          UserStatus @default(INVITED)
  isOwner         Boolean    @default(false)
  canViewAllCases Boolean    @default(false)
  mfaEnabled      Boolean    @default(false)
  mfaSecret       String?
  mfaVerifiedAt   DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  reports        WhistleReport[]       @relation("UserReports")
  messages       ReportMessage[]       @relation("UserMessages")
  statusLogs     ReportStatusHistory[] @relation("UserStatusLogs")
  UserToken      UserToken[]
  RefreshSession RefreshSession[]
  recoveryCodes  UserRecoveryCode[]

  @@unique([clientId, email])
  @@index([clientId])
}

// Utenti pubblici (segnalatori esterni)
model PublicUser {
  id        String         @id @default(cuid())
  clientId  String
  token     String         @unique @db.VarChar(128) // sha256
  reportId  String?
  report    WhistleReport? @relation(fields: [reportId], references: [id])
  createdAt DateTime       @default(now())

  @@index([clientId])
  @@index([token])
}

////////////////////////////////////////////////////
// REPORTING
////////////////////////////////////////////////////

// Segnalazioni
model WhistleReport {
  id             String        @id @default(cuid())
  clientId       String
  publicCode     String        @unique
  secretHash     String        @db.VarChar(128) // sha256
  status         ReportStatus  @default(OPEN)
  title          String
  summary        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deadline       DateTime?
  acknowledgeAt  DateTime?
  channel        ReportChannel @default(WEB)
  closedAt       DateTime?
  consentGivenAt DateTime?
  consentVersion String?
  dueAt          DateTime?
  locale         String?

  // Timestamp transizioni di stato (per logica SLA)
  openAt        DateTime? @default(now())
  inProgressAt  DateTime?
  finalClosedAt DateTime?

  // Campi public form
  eventDate   DateTime     @default(now())
  privacy     ReporterPrivacy @default(ANONIMO)
  departmentId String?
  categoryId   String?
  containsPIISuspected Boolean @default(false)
  ipHash      String?     @db.VarChar(128)
  ua          String?
  retentionAt DateTime?

  internalUserId String?
  internalUser   InternalUser? @relation("UserReports", fields: [internalUserId], references: [id])

  publicUsers PublicUser[]
  messages    ReportMessage[]
  statusLogs  ReportStatusHistory[]
  attachments ReportAttachment[]
  accessLogs  ReportAccessLog[]

  @@index([clientId])
  @@index([status])
  @@index([clientId, publicCode])
}

// Messaggi delle segnalazioni
model ReportMessage {
  id        String   @id @default(cuid())
  clientId  String
  reportId  String
  author    String
  body      String
  createdAt DateTime @default(now())

  // Nota interna (admin/agent)
  note String?

  report WhistleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  authorId String?
  user     InternalUser? @relation("UserMessages", fields: [authorId], references: [id])

  // Visibilità del messaggio
  visibility MessageVisibility @default(INTERNAL)

  @@index([reportId])
  @@index([clientId])
  @@index([reportId, createdAt])
  @@index([reportId, visibility])
}

// Visibilità dei messaggi
enum MessageVisibility {
  PUBLIC
  INTERNAL
  SYSTEM
}

// Storico cambi di stato
model ReportStatusHistory {
  id         String       @id @default(cuid())
  clientId   String
  reportId   String
  note       String?
  author     String?
  agentId    String?
  modifiedAt DateTime     @default(now())
  status     ReportStatus

  report WhistleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  agent  InternalUser? @relation("UserStatusLogs", fields: [agentId], references: [id])

  @@index([reportId])
  @@index([clientId])
  @@index([status])
}

// Metadati allegati dei report (upload via presign)
model ReportAttachment {
  id         String   @id @default(cuid())
  reportId   String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime @default(now())

  report WhistleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Stato pipeline allegati
  status     AttachmentStatus @default(UPLOADED)
  etag       String?
  finalKey   String?
  scannedAt  DateTime?
  virusName  String?

  @@index([reportId])
}

// --- NEW: Token di invito/reset split (selector + tokenHash) ---
model UserToken {
  id        String        @id @default(cuid())
  userId    String
  clientId  String
  type      UserTokenType
  selector  String        @unique
  tokenHash String        @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
  ip        String?
  ua        String?

  user InternalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId, userId, type, expiresAt])
}

// --- NEW: Sessioni refresh con rotazione e revoke ---
model RefreshSession {
  id            String    @id @default(uuid()) // jti
  userId        String
  clientId      String
  hash          String    @db.VarChar(128)
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  rotatedFromId String?
  ip            String?
  ua            String?

  user        InternalUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotatedFrom RefreshSession?  @relation("RefreshRotation", fields: [rotatedFromId], references: [id])
  rotatedTo   RefreshSession[] @relation("RefreshRotation")

  @@index([userId, clientId])
  @@index([expiresAt])
}

// --- NEW: Codici di recupero MFA ---
model UserRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @db.VarChar(128)
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user InternalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

// --- NEW: Access log per audit (view/export)
model ReportAccessLog {
  id        String   @id @default(cuid())
  reportId  String
  userId    String
  clientId  String
  action    String   // VIEW | EXPORT | LIST | OTHER
  ip        String?
  ua        String?
  createdAt DateTime @default(now())

  report WhistleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([userId, createdAt])
  @@index([clientId, createdAt])
}

// Stato allegati durante pipeline di scan/promozione
enum AttachmentStatus {
  UPLOADED
  SCANNING
  CLEAN
  INFECTED
}
