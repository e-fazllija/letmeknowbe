// ---------- GENERATOR & DATASOURCE ----------
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

////////////////////////////////////////////////////
// ENUM
////////////////////////////////////////////////////
enum PaymentMethod {
  CARTA
  BONIFICO
}

enum EmployeeRange {
  DA_0_A_50
  DA_51_A_100
  DA_101_A_150
  DA_151_A_200
  DA_201_A_250
  OLTRE_250
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  SUSPENDED
  CLOSED
}

enum ReportChannel {
  WEB
  PHONE
  EMAIL
  OTHER
}

// Stato cliente (coerente col public)
enum ClientStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

// Ciclo fatturazione (coerente col public)
enum BillingCycle {
  MENSILE
  ANNUALE
}

// Durata contrattuale (coerente col public)
enum ContractTerm {
  ONE_YEAR
  THREE_YEARS
}

// Stato subscription (coerente col public)
enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

////////////////////////////////////////////////////
// MODELS
////////////////////////////////////////////////////

// Azienda cliente (tenant)
model Client {
  id            String         @id @default(cuid())
  companyName   String
  contactEmail  String
  status        ClientStatus   @default(ACTIVE)
  employeeRange EmployeeRange
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyName])
}

// Abbonamenti (shadow minimale nel tenant: NO dati economici)
model Subscription {
  id            String             @id @default(cuid())
  clientId      String
  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  billingCycle  BillingCycle
  contractTerm  ContractTerm
  status        SubscriptionStatus @default(ACTIVE)
  startsAt      DateTime           @default(now())
  nextBillingAt DateTime?
  createdAt     DateTime           @default(now())

  @@index([clientId])
}

// Utenti interni (admin, agent)
model InternalUser {
  id        String   @id @default(cuid())
  clientId  String
  email     String   @unique
  password  String
  role      String // ADMIN, AGENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports    WhistleReport[]       @relation("UserReports")
  messages   ReportMessage[]       @relation("UserMessages")
  statusLogs ReportStatusHistory[] @relation("UserStatusLogs")
}

// Utenti pubblici (segnalatori esterni)
model PublicUser {
  id        String         @id @default(cuid())
  clientId  String
  token     String         @unique @db.VarChar(128) // sha256
  reportId  String?
  report    WhistleReport? @relation(fields: [reportId], references: [id])
  createdAt DateTime       @default(now())

  @@index([clientId])
  @@index([token])
}

////////////////////////////////////////////////////
// REPORTING
////////////////////////////////////////////////////

// Segnalazioni
model WhistleReport {
  id             String        @id @default(cuid())
  clientId       String
  publicCode     String        @unique
  secretHash     String        @db.VarChar(128) // sha256
  status         ReportStatus  @default(OPEN)
  title          String
  summary        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deadline       DateTime?
  acknowledgeAt  DateTime?
  channel        ReportChannel @default(WEB)
  closedAt       DateTime?
  consentGivenAt DateTime?
  consentVersion String?
  dueAt          DateTime?
  locale         String?

  // Timestamp transizioni di stato (per logica SLA)
  openAt        DateTime? @default(now())
  inProgressAt  DateTime?
  finalClosedAt DateTime?

  internalUserId String?
  internalUser   InternalUser? @relation("UserReports", fields: [internalUserId], references: [id])

  publicUsers PublicUser[]
  messages    ReportMessage[]
  statusLogs  ReportStatusHistory[]

  @@index([clientId])
  @@index([status])
}

// Messaggi delle segnalazioni
model ReportMessage {
  id        String   @id @default(cuid())
  clientId  String
  reportId  String
  author    String
  body      String
  createdAt DateTime @default(now())

  // Nota interna (admin/agent)
  note      String?

  report   WhistleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  authorId String?
  user     InternalUser? @relation("UserMessages", fields: [authorId], references: [id])

  @@index([reportId])
  @@index([clientId])
}

// Storico cambi di stato
model ReportStatusHistory {
  id         String       @id @default(cuid())
  clientId   String
  reportId   String
  note       String?
  author     String?
  agentId    String?
  modifiedAt DateTime     @default(now())
  status     ReportStatus

  report WhistleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  agent  InternalUser? @relation("UserStatusLogs", fields: [agentId], references: [id])

  @@index([reportId])
  @@index([clientId])
  @@index([status])
}
